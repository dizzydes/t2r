# Infracost credentials
# Get your API key from: https://www.infracost.io/
INFRACOST_API_KEY=your_infracost_api_key_here
INFRACOST_CLI_TOKEN=your_infracost_cli_token_here
INFRACOST_ORG_ID=your_org_id_here
INFRACOST_ORG_SLUG=your_org_slug_here

# OpenRouter API key
# Get your API key from: https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here
